# =============================================================================
# LinkWork Docker 部署 — 环境变量模板
# 复制为 .env 后编辑:  cp .env.example .env
# =============================================================================

# ----- 版本 -----
LINKWORK_VERSION=latest

# ===== 基础设施（容器内部地址，一般不需要改） =====
LINKWORK_DB_URL=jdbc:mysql://mysql:3306/linkwork?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8
LINKWORK_DB_USERNAME=linkwork
LINKWORK_DB_PASSWORD=linkwork123
MYSQL_ROOT_PASSWORD=linkwork_root

REDIS_HOST=redis

# Docker daemon（DinD 模式，override 会覆盖为 Socket）
DOCKER_HOST=tcp://dind:2376

# Memory（默认关闭，启用需 --profile memory）
MEMORY_ENABLED=false
MILVUS_URI=http://milvus:19530

# ===== 调度配置（Docker 模式专用） =====
LINKWORK_SANDBOX_PROVIDER=compose
IMAGE_PULL_POLICY=Never
IMAGE_REGISTRY=
OSS_MOUNT_ENABLED=false

# ===== 平台服务内部通信 =====
API_BASE_URL=http://linkwork-backend:8081
WS_BASE_URL=ws://linkwork-backend:8081
LLM_GATEWAY_URL=http://litellm:4000

# MCP Gateway
WEB_SERVICE_BASE_URL=http://linkwork-backend:8081
REDIS_ADDR=redis:6379

# ===== 需要用户填写的外部凭证 =====

# LLM API Key（填写后可通过 --profile llm 启动 litellm 网关）
LITELLM_API_KEY=
# 或直接填 OpenAI/Anthropic 等 LLM 提供商 URL
LITELLM_BASE_URL=

# 登录密码（BCrypt 哈希，可用 htpasswd -nbBC 10 "" 'your-password' | cut -d: -f2 生成）
AUTH_PASSWORD=
# JWT 密钥（至少 32 字符随机字符串）
AUTH_JWT_SECRET=

# ===== 可选：宿主机端口映射 =====
# MYSQL_PORT=3306
# REDIS_PORT=6379
# BACKEND_PORT=8081
# GATEWAY_PORT=9080
# WEB_PORT=3003
# MILVUS_PORT=19530
# LITELLM_PORT=4000
